GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

DATABASE_URL=sqlite+aiosqlite:///./data/assistant.db
CHROMA_DB_PATH=./data/chroma

BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Web Push (VAPID keys - 用指令生成)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=your@email.com

# Agent 連線 Token
AGENT_SECRET_TOKEN=change_this_secret_token

# ── 遠端控制（讓 AI 從 Discord 遠端操作）──
# 設定一個強密碼，之後把這個 token 傳給 AI
REMOTE_ACCESS_TOKEN=your_strong_remote_token_here
# WSL 中專案的絕對路徑（用來讀取 log 檔）
PROJECT_ROOT=/home/你的帳號/personal-ai-assistant
